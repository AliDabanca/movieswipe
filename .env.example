# Environment Configuration Template
# Copy this file to create your own environment files:
# For Development: cp .env.example .env.dev
# For Test: cp .env.example .env.test
# For Production: cp .env.example .env.prod

# Network Configuration
# IMPORTANT: Replace <YOUR_LOCAL_IP> with your computer's IP address
# 
# To find your IP:
#   Windows: ipconfig | findstr /i "IPv4"
#   Mac/Linux: ifconfig | grep "inet "
#
# For Android Emulator use: http://10.0.2.2:8000
# For iOS Simulator use: http://localhost:8000
# For Physical Device use: http://<YOUR_LOCAL_IP>:8000

BASE_URL=http://<YOUR_LOCAL_IP>:8000
API_TIMEOUT=30000
ENVIRONMENT=development
